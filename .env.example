# Story Configuration — Environment Variables
# Copy to .env and fill in your values.

# Database
STORY_DATABASE_PASSWORD=changeme

# Auth
STORY_AUTH_JWT_SECRET=your-256-bit-jwt-secret-here-change-in-production

# LLM Provider
# For OpenAI:
OPENAI_API_KEY=
# For Gemini:
GEMINI_API_KEY=
# For Anthropic:
ANTHROPIC_API_KEY=

# SMTP (password reset emails)
STORY_SMTP_PASSWORD=

# ─────────────────────────────────────────────────────────
# Story — Environment Variables
# ─────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# Secrets must be set via environment, never committed to version control.

# Required: database credentials
STORY_DATABASE_PASSWORD=changeme

# Required: JWT signing key (min 32 characters, use a secure random value)
STORY_AUTH_JWT_SECRET=your-256-bit-jwt-secret-here-change-in-production

# Database connection string for goose migrations
# Format: postgres://user:password@host:port/database?sslmode=disable
STORY_DATABASE_DSN=postgres://story:changeme@localhost:5432/story?sslmode=disable

# Optional: config file path (defaults to configs/config.yaml)
# STORY_CONFIG_PATH=configs/config.yaml

# Optional: override individual config values
# STORY_APP_ENVIRONMENT=development
# STORY_DATABASE_HOST=localhost
# STORY_DATABASE_PORT=5432
# STORY_SERVER_PORT=8080

# Optional: LLM provider API keys (for publishing/transformation features)
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# ANTHROPIC_API_KEY=

# Optional: SMTP credentials (for password reset emails)
# STORY_SMTP_PASSWORD=
